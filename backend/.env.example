# Database
DATABASE_URL=sqlite:///./test.db

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:3000"]

# LLM Provider (openai or anthropic)
LLM_PROVIDER=openai

# OpenAI
# 実際のAPIキーはOpenAIダッシュボードから取得してください
# 形式: sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-REPLACE_WITH_YOUR_OPENAI_API_KEY
OPENAI_MODEL=gpt-4o-mini

# Anthropic
# 実際のAPIキーはAnthropicコンソールから取得してください
# 形式: sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_API_KEY=sk-ant-REPLACE_WITH_YOUR_ANTHROPIC_API_KEY
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
