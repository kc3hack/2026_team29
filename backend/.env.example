# Database
DATABASE_URL=sqlite:///./test.db

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:3000"]

# Encryption (OAuth Token Protection)
# 暗号化キーは以下のコマンドで生成してください:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# 形式: 32バイトのbase64エンコード文字列
ENCRYPTION_KEY=REPLACE_WITH_GENERATED_FERNET_KEY

# Admin API Access Control
# 管理APIへのアクセスに必要なAPIキー（任意の文字列）
# セキュアなランダム文字列を設定してください
ADMIN_API_KEY=your-secure-admin-api-key-here

# LLM Provider (openai or anthropic)
LLM_PROVIDER=openai

# OpenAI
# 実際のAPIキーはOpenAIダッシュボードから取得してください
# 形式: sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-REPLACE_WITH_YOUR_OPENAI_API_KEY
OPENAI_MODEL=gpt-4o-mini

# Anthropic
# 実際のAPIキーはAnthropicコンソールから取得してください
# 形式: sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_API_KEY=sk-ant-REPLACE_WITH_YOUR_ANTHROPIC_API_KEY
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# GitHub API (スキルツリー生成で使用)
# オプション: 設定しなくても動作しますが、Rate Limit緩和のため推奨
# Personal Access Token (Classic): https://github.com/settings/tokens
# 必要なスコープ: public_repo (read:user は自動で含まれます)
# 形式: ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Rate Limit: 未設定 60req/h, 設定済み 5000req/h
GITHUB_API_TOKEN=

# Skill Tree Cache (スキルツリーキャッシュ有効期間)
# ハッカソン用: 10分、本番用: 推奨値は数時間〜数日
# 単位: 分
# SKILL_TREE_CACHE_MINUTES=10
